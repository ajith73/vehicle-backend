# Backend Environment Variables Example

# Port for the Express server to run on
PORT=5000

# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET=supersecret_mvp_key_change_me_in_prod

# Super Admin Default Credentials
# These will be seeded on the first database initialization
SUPERADMIN_USERNAME=admin@example.com
SUPERADMIN_PASSWORD=admin123

# Local Database Connection URL (PostgreSQL or Supabase Local)
DATABASE_URL_LOCAL=postgresql://postgres:[YOUR-PASSWORD]@localhost:5432/vehicle_repair_local

# Production Supabase (PostgreSQL) Database Connection URL
DATABASE_URL_PROD=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# production or development
NODE_ENV=production